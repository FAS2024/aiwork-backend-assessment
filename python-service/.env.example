# Python service (InsightOps) — copy to .env and run from python-service/
# Prerequisite: start Postgres with `docker compose up -d postgres` from repo root

# PostgreSQL (must match docker-compose: assessment_db / assessment_user / assessment_pass)
DATABASE_URL=postgresql+psycopg://assessment_user:assessment_pass@localhost:5432/assessment_db

# Optional
APP_ENV=development
APP_PORT=8000
