# TypeScript service (TalentFlow) — copy to .env and run from ts-service/
# Prerequisite: start Postgres with `docker compose up -d postgres` from repo root

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (must match docker-compose: assessment_db / assessment_user / assessment_pass)
DATABASE_URL=postgres://assessment_user:assessment_pass@localhost:5432/assessment_db

# Optional: real LLM summarization. Leave empty to use in-memory fake provider (no API calls).
# Get a free key at https://aistudio.google.com/apikey — do not commit this value.
GEMINI_API_KEY=
